generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// 用户表 - 存储所有注册用户
model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  avatar      String?
  bio         String?
  role        UserRole     @default(USER)
  password    String?
  aiConfig    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  accounts    Account[]
  collections Collection[]
  comments    Comment[]
  contents    Content[]
  ratings     Rating[]
  sessions    Session[]

  @@index([email])
  @@map("users")
}

/// Auth.js - 账户表（OAuth 登录）
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

/// Auth.js - 会话表
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

/// Auth.js - 验证令牌表
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// 分类表 - 行业分类（软件、建筑、法律、设计、社媒运营等）
model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  icon      String?
  sortOrder Int        @default(0)
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  contents  Content[]

  @@index([slug])
  @@map("categories")
}

/// 内容表 - 存储 Skill
model Content {
  id              String        @id @default(cuid())
  name            String
  description     String
  authorId        String
  toolsConfig     Json?
  categoryId      String
  status          ContentStatus @default(DRAFT)
  isFeatured      Boolean       @default(false)
  viewCount       Int           @default(0)
  downloadCount   Int           @default(0)
  avgRating       Float?
  ratingCount     Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  publishedAt     DateTime?
  content         String?
  favoriteCount   Int           @default(0)
  license         String        @default("MIT-0")
  version         String        @default("v1.0.0")
  versionNotes    String?
  // 版本关联：新版本指向原始 Skill
  parentContentId String?
  collections     Collection[]
  comments        Comment[]
  tags            ContentTag[]
  author          User          @relation(fields: [authorId], references: [id])
  category        Category      @relation(fields: [categoryId], references: [id])
  files           File[]
  ratings         Rating[]
  // 版本历史关联
  parentContent   Content?      @relation("SkillVersions", fields: [parentContentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  versions        Content[]    @relation("SkillVersions")

  @@index([status])
  @@index([categoryId])
  @@index([authorId])
  @@index([createdAt(sort: Desc)])
  @@index([viewCount(sort: Desc)])
  @@index([avgRating(sort: Desc)])
  @@index([parentContentId])
  @@map("contents")
}

/// 标签表
model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  slug     String       @unique
  contents ContentTag[]

  @@map("tags")
}

/// 内容-标签关联表（多对多）
model ContentTag {
  contentId String
  tagId     String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentId, tagId])
  @@map("content_tags")
}

/// 文件表 - 存储上传的脚本、模板等
model File {
  id          String   @id @default(cuid())
  contentId   String
  filename    String
  type        String
  size        Int
  createdAt   DateTime @default(now())
  fileContent String?
  path        String
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@map("files")
}

/// 评论表
model Comment {
  id        String   @id @default(cuid())
  contentId String
  userId    String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contentId, createdAt(sort: Desc)])
  @@map("comments")
}

/// 评分表
model Rating {
  id        String   @id @default(cuid())
  contentId String
  userId    String
  score     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contentId, userId])
  @@map("ratings")
}

/// 收藏表
model Collection {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  createdAt DateTime @default(now())
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([userId])
  @@map("collections")
}

enum UserRole {
  USER
  ADMIN
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
